# ─────────────────────────────────────────────────────────────────────────────
# tesla-nowplaying configuration. Copy this file to `.env` and fill it in:
#     cp .env.example .env
# `.env` is git-ignored; never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── TeslaMate database ─────────────────────────────────────────────────────────
# The app reads TeslaMate's already-stored, encrypted Tesla access token straight
# from its Postgres database, so you don't manage a separate Tesla login. These
# must match your TeslaMate install (see TeslaMate's own .env / docker-compose).
TM_DB_HOST=database
TM_DB_NAME=teslamate
TM_DB_USER=teslamate
TM_DB_PASS=changeme
TM_ENCRYPTION_KEY=changeme

# Name of TeslaMate's docker network to attach to, so the DB host above resolves.
TESLAMATE_NETWORK=teslamate_default

# ── Tesla ──────────────────────────────────────────────────────────────────────
# teslamate_db = reuse TeslaMate's token (recommended).
# file         = legacy: maintain your own refresh token in TOKEN_FILE.
TOKEN_SOURCE=teslamate_db
TESLA_API_HOST=https://owner-api.teslamotors.com
# Leave blank to auto-detect the first vehicle on the account.
TESLA_VIN=
# Only needed when TOKEN_SOURCE=file (self-hosted Fleet API client id).
TESLA_AUTH_CLIENT_ID=

# ── App / features ─────────────────────────────────────────────────────────────
# Lyric translation target (Google gtx language code). Lyrics already in this
# language are not translated, so no duplicate "double subtitle" is shown.
TRANSLATE_TARGET_LANG=zh-CN
# Seconds to cache the decrypted access token / the /api/state vehicle read.
TESLAMATE_ACCESS_TTL=60
STATE_TTL=1.0

# Where to publish the web UI on the host. Keep 127.0.0.1 and put a reverse
# proxy + authentication in front of it for any remote access. The container
# always listens on port 8475 internally.
HTTP_BIND_ADDR=127.0.0.1
HTTP_PORT=8475
